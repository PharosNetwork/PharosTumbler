package(default_visibility = ["//visibility:public"])
cc_library(
    name = "asio",
    srcs = glob([
        "**/*.hpp",
        "include/**/*.hpp",
        "include/asio/**/*.hpp",
    ]),
    hdrs = glob([
        "**/*.hpp",
        "include/**/*.hpp",
        "include/asio/**/*.hpp",
        "**/*.ipp",
        "include/**/*.ipp",
        "include/asio/**/*.ipp",


    ]),
    includes = ["include", "src", "include/asio"],
    visibility = ["//visibility:public"],
)
